{
    "manifest_version" : 3,
    "name" : "Codelytics Sync",
    "version" : "1.0",
    "description" : "Sync your Leetcode and GFG submissions to Codelytics",
    "permissions": ["storage", "cookies", "tabs"],

    "host_permissions": [
        "<all_urls>"
    ],

    "content_scripts": [{
        "matches": ["*://*.geeksforgeeks.org/*", "*://geeksforgeeks.org/*"],
        "js": ["content.js"],
        "run_at": "document_idle"
    }],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup.html",
        "default_title": "Codelytics Sync"
    }

}